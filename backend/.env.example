# Copy this file to .env and fill in your values.
# On Render, set these as Environment Variables in the dashboard.

# Comma-separated list of allowed frontend origins (JSON array format)
ALLOWED_ORIGINS=["https://afonsobranco.github.io", "http://localhost:5173"]

# Cache TTL in seconds (default: 900 = 15 minutes)
CACHE_TTL_SECONDS=900

# Environment: "development" | "production"
APP_ENV=production
